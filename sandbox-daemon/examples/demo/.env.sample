# Environment for the faradayd demo daemon. Copy to `.env` and `set -a; . ./.env; set +a`
# (or export each) before launching `faradayd`. Loopback http issuer is permitted for a
# local IdP (ADR-029); remote http is rejected.
PYS_OIDC_ISSUER=http://127.0.0.1:5556/dex
PYS_OIDC_CLIENT_ID=faradayd
PYS_OIDC_SCOPES=openid profile email

# The dummy capability is a DIRECT provider (no obo-broker needed for the demo).
PYS_POLICY_PATH=./examples/demo/pysandbox.policy.json

# The bundled guest digest (must match CHECKSUMS.txt).
PYS_GUEST_ARTIFACT_DIGEST=fd4e2842e7b17dc60e2fd0dfc12db4bcd6821b85a35f2909dd3883b1bcba88fb

# Audit HMAC key reference (FileSecretResolver reads this path). Create it first:
#   head -c 32 /dev/urandom > ./examples/demo/audit.key
PYS_AUDIT_HMAC_KEY_REF=./examples/demo/audit.key

# Mock credential mode (no OTLP sink configured) — sufficient for the local demo.
# PYS_OTLP_ENDPOINT=   # set only for real-credential mode (ADR-016)
